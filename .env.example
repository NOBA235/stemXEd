# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (SERVER ONLY - never prefix with NEXT_PUBLIC_)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# Stripe (SERVER ONLY)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxx

# Stripe Price IDs
STRIPE_BASIC_MONTHLY_PRICE_ID=price_xxxxxxxxxx
STRIPE_BASIC_YEARLY_PRICE_ID=price_xxxxxxxxxx
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_xxxxxxxxxx
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_xxxxxxxxxx

# Email
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=noreply@solvr.ai

# App
NEXT_PUBLIC_APP_URL=https://solvr.ai
CRON_SECRET=generate-random-string-here
